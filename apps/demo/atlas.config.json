{
  "include": [
    "src/**/*.tsx",
    "src/**/*.jsx"
  ],
  "exclude": [
    "**/*.test.tsx",
    "**/*.test.jsx",
    "**/*.spec.tsx",
    "**/*.spec.jsx",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**"
  ],
  "components": [
